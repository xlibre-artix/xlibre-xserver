From 47c25e0837126aa25686ab7b85f02200289e908d Mon Sep 17 00:00:00 2001
From: Dongwon Kim <dongwon.kim@intel.com>
Date: Sun, 15 Mar 2026 13:12:16 +0200
Subject: [PATCH] modesetting: Empty damage once dispatch is done

This commit is to fix some regression caused by

commit https://gitlab.freedesktop.org/xorg/xserver/-/commit/995e60a91997a00768517d1ab6b40fc4f78b7cdc

where DamageEmpty on damage was missing in several
places.

Signed-off-by: Dongwon Kim <dongwon.kim@intel.com>
Part-of: <https://gitlab.freedesktop.org/xorg/xserver/-/merge_requests/1486>
---
 hw/xfree86/drivers/video/modesetting/driver.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/hw/xfree86/drivers/video/modesetting/driver.c b/hw/xfree86/drivers/video/modesetting/driver.c
index c43df83fe1..97bbf18096 100644
--- a/hw/xfree86/drivers/modesetting/driver.c
+++ b/hw/xfree86/drivers/modesetting/driver.c
@@ -782,6 +782,8 @@ dispatch_dirty(ScreenPtr pScreen)
             return;
         }
     }
+
+    DamageEmpty(ms->damage);
 }
 
 static void
@@ -793,6 +795,8 @@ dispatch_dirty_pixmap(ScrnInfoPtr scrn, xf86CrtcPtr crtc, PixmapPtr ppix)
     int fb_id = ppriv->fb_id;
 
     dispatch_dirty_region(scrn, crtc, ppix, damage, fb_id, 0, 0);
+    if (damage)
+        DamageEmpty(damage);
 }
 
 static void
